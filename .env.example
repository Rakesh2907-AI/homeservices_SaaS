# ===== Database =====
DATABASE_URL=postgresql://saas_user:saas_password@localhost:5432/homeservices
DATABASE_READ_URL=postgresql://saas_user:saas_password@localhost:5432/homeservices
DB_POOL_MIN=2
DB_POOL_MAX=10

# ===== Redis =====
REDIS_URL=redis://localhost:6379
REDIS_PREFIX=hs

# ===== JWT / Auth =====
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_EXPIRES_IN=8h
REFRESH_TOKEN_EXPIRES_IN=30d

# ===== Service Ports =====
API_GATEWAY_PORT=3000
TENANT_SERVICE_PORT=3001
AUTH_SERVICE_PORT=3002
BOOKING_SERVICE_PORT=3003
PRICING_SERVICE_PORT=3004
NOTIFICATION_SERVICE_PORT=3005

# ===== App Config =====
NODE_ENV=development
LOG_LEVEL=info
APP_BASE_DOMAIN=localhost:3000

# ===== AWS (for production) =====
AWS_REGION=us-east-1
S3_ASSETS_BUCKET=homeservices-assets
CLOUDFRONT_DOMAIN=

# ===== Feature Flags (Unleash) =====
UNLEASH_URL=http://localhost:4242/api
UNLEASH_API_TOKEN=
